digraph REL {
graph [rankdir=LR, bgcolor="white", pad="0.3", nodesep="0.5", ranksep="1.0", splines=polyline, fontname="Arial"];
node [fontname="Arial", fontsize=8];
edge [fontname="Arial", fontsize=7, color="#444444", arrowsize=0.7];
dim_date [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#DCEBFA" COLSPAN="3"><B>dim_date</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="date_key" ALIGN="LEFT">date_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="full_date" ALIGN="LEFT">full_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"><B>AK</B></TD></TR><TR><TD PORT="day_of_month" ALIGN="LEFT">day_of_month</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="iso_day_of_week" ALIGN="LEFT">iso_day_of_week</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="day_name" ALIGN="LEFT">day_name</TD><TD ALIGN="LEFT">varchar(12)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="week_of_year" ALIGN="LEFT">week_of_year</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="month_number" ALIGN="LEFT">month_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="month_name" ALIGN="LEFT">month_name</TD><TD ALIGN="LEFT">varchar(12)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="quarter_number" ALIGN="LEFT">quarter_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="year_number" ALIGN="LEFT">year_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="is_weekend" ALIGN="LEFT">is_weekend</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
dim_time [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#DCEBFA" COLSPAN="3"><B>dim_time</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="time_key" ALIGN="LEFT">time_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="full_time" ALIGN="LEFT">full_time</TD><TD ALIGN="LEFT">time</TD><TD ALIGN="LEFT"><B>AK</B></TD></TR><TR><TD PORT="hour_number" ALIGN="LEFT">hour_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="minute_number" ALIGN="LEFT">minute_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="second_number" ALIGN="LEFT">second_number</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="minute_of_day" ALIGN="LEFT">minute_of_day</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="time_bucket" ALIGN="LEFT">time_bucket</TD><TD ALIGN="LEFT">varchar(20)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
dim_station [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#DCEBFA" COLSPAN="3"><B>dim_station</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="station_key" ALIGN="LEFT">station_key</TD><TD ALIGN="LEFT">bigint identity</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="station_id" ALIGN="LEFT">station_id</TD><TD ALIGN="LEFT">varchar(10)</TD><TD ALIGN="LEFT"><B>AK</B></TD></TR><TR><TD PORT="station_name" ALIGN="LEFT">station_name</TD><TD ALIGN="LEFT">varchar(160)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="location" ALIGN="LEFT">location</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="device_type" ALIGN="LEFT">device_type</TD><TD ALIGN="LEFT">varchar(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="payload" ALIGN="LEFT">payload</TD><TD ALIGN="LEFT">varchar(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="latitude" ALIGN="LEFT">latitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="longitude" ALIGN="LEFT">longitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="water_depth_meter" ALIGN="LEFT">water_depth_meter</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="station_status" ALIGN="LEFT">station_status</TD><TD ALIGN="LEFT">varchar(40)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="provider_name" ALIGN="LEFT">provider_name</TD><TD ALIGN="LEFT">varchar(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="provider_base_url" ALIGN="LEFT">provider_base_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="detail_url" ALIGN="LEFT">detail_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="realtime_data_url" ALIGN="LEFT">realtime_data_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_created_at" ALIGN="LEFT">source_created_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_updated_at" ALIGN="LEFT">source_updated_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_created_at" ALIGN="LEFT">dw_created_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_updated_at" ALIGN="LEFT">dw_updated_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
dim_scrape_run [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#DCEBFA" COLSPAN="3"><B>dim_scrape_run</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="scrape_run_key" ALIGN="LEFT">scrape_run_key</TD><TD ALIGN="LEFT">bigint identity</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="scrape_run_id" ALIGN="LEFT">scrape_run_id</TD><TD ALIGN="LEFT">varchar(64)</TD><TD ALIGN="LEFT"><B>AK</B></TD></TR><TR><TD PORT="started_at" ALIGN="LEFT">started_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="finished_at" ALIGN="LEFT">finished_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="target_met" ALIGN="LEFT">target_met</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="station_list_source_url" ALIGN="LEFT">station_list_source_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_output_directory" ALIGN="LEFT">source_output_directory</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_loaded_at" ALIGN="LEFT">source_loaded_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_created_at" ALIGN="LEFT">dw_created_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_updated_at" ALIGN="LEFT">dw_updated_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
fact_observation [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#FCE8D5" COLSPAN="3"><B>fact_observation</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="observation_fact_key" ALIGN="LEFT">observation_fact_key</TD><TD ALIGN="LEFT">bigint identity</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="station_key" ALIGN="LEFT">station_key</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="date_key" ALIGN="LEFT">date_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="time_key" ALIGN="LEFT">time_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="first_seen_scrape_run_key" ALIGN="LEFT">first_seen_scrape_run_key</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="observed_at_utc" ALIGN="LEFT">observed_at_utc</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"><B>AK*</B></TD></TR><TR><TD PORT="wind_direction_degree" ALIGN="LEFT">wind_direction_degree</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="wind_speed_meter_per_second" ALIGN="LEFT">wind_speed_meter_per_second</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="wind_gust_meter_per_second" ALIGN="LEFT">wind_gust_meter_per_second</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="wave_height_meter" ALIGN="LEFT">wave_height_meter</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dominant_wave_period_second" ALIGN="LEFT">dominant_wave_period_second</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="average_wave_period_second" ALIGN="LEFT">average_wave_period_second</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="mean_wave_direction_degree" ALIGN="LEFT">mean_wave_direction_degree</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="sea_surface_temperature_celsius" ALIGN="LEFT">sea_surface_temperature_celsius</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="measurement_count" ALIGN="LEFT">measurement_count</TD><TD ALIGN="LEFT">smallint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="has_wind_measurement" ALIGN="LEFT">has_wind_measurement</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="has_wave_measurement" ALIGN="LEFT">has_wave_measurement</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="has_temperature_measurement" ALIGN="LEFT">has_temperature_measurement</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_row_number" ALIGN="LEFT">source_row_number</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_url" ALIGN="LEFT">source_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_extracted_at" ALIGN="LEFT">source_extracted_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_loaded_at" ALIGN="LEFT">source_loaded_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_loaded_at" ALIGN="LEFT">dw_loaded_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
fact_scrape_run [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#FCE8D5" COLSPAN="3"><B>fact_scrape_run</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="scrape_run_fact_key" ALIGN="LEFT">scrape_run_fact_key</TD><TD ALIGN="LEFT">bigint identity</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="scrape_run_key" ALIGN="LEFT">scrape_run_key</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"><B>FK/AK</B></TD></TR><TR><TD PORT="started_date_key" ALIGN="LEFT">started_date_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="started_time_key" ALIGN="LEFT">started_time_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="finished_date_key" ALIGN="LEFT">finished_date_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="finished_time_key" ALIGN="LEFT">finished_time_key</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"><B>FK</B></TD></TR><TR><TD PORT="duration_second" ALIGN="LEFT">duration_second</TD><TD ALIGN="LEFT">numeric(18,3)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="target_station_count" ALIGN="LEFT">target_station_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_candidate_count" ALIGN="LEFT">source_candidate_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="processed_candidate_count" ALIGN="LEFT">processed_candidate_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="successful_station_count" ALIGN="LEFT">successful_station_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="skipped_non_buoy_count" ALIGN="LEFT">skipped_non_buoy_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="skipped_no_data_count" ALIGN="LEFT">skipped_no_data_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="failed_attempt_count" ALIGN="LEFT">failed_attempt_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_observation_count" ALIGN="LEFT">source_observation_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="duplicate_observation_count" ALIGN="LEFT">duplicate_observation_count</TD><TD ALIGN="LEFT">integer</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="dw_loaded_at" ALIGN="LEFT">dw_loaded_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
etl_batch [shape=plain, label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="3"><TR><TD BGCOLOR="#ECECEC" COLSPAN="3"><B>etl_batch</B></TD></TR><TR><TD><B>column</B></TD><TD><B>type</B></TD><TD><B>key</B></TD></TR><TR><TD PORT="etl_batch_id" ALIGN="LEFT">etl_batch_id</TD><TD ALIGN="LEFT">bigint identity</TD><TD ALIGN="LEFT"><B>PK</B></TD></TR><TR><TD PORT="started_at" ALIGN="LEFT">started_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="finished_at" ALIGN="LEFT">finished_at</TD><TD ALIGN="LEFT">timestamptz</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="status" ALIGN="LEFT">status</TD><TD ALIGN="LEFT">varchar(20)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_station_count" ALIGN="LEFT">source_station_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_scrape_run_count" ALIGN="LEFT">source_scrape_run_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="source_observation_count" ALIGN="LEFT">source_observation_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="inserted_station_count" ALIGN="LEFT">inserted_station_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="inserted_scrape_run_count" ALIGN="LEFT">inserted_scrape_run_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="inserted_observation_count" ALIGN="LEFT">inserted_observation_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="total_station_count" ALIGN="LEFT">total_station_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="total_scrape_run_count" ALIGN="LEFT">total_scrape_run_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR><TR><TD PORT="total_observation_count" ALIGN="LEFT">total_observation_count</TD><TD ALIGN="LEFT">bigint</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
fact_observation:station_key:e -> dim_station:station_key:w [label="N:1"];
fact_observation:date_key:e -> dim_date:date_key:w [label="N:1"];
fact_observation:time_key:e -> dim_time:time_key:w [label="N:1"];
fact_observation:first_seen_scrape_run_key:e -> dim_scrape_run:scrape_run_key:w [label="N:1"];
fact_scrape_run:scrape_run_key:e -> dim_scrape_run:scrape_run_key:w [label="1:1"];
fact_scrape_run:started_date_key:e -> dim_date:date_key:w [label="N:1 start"];
fact_scrape_run:started_time_key:e -> dim_time:time_key:w [label="N:1 start"];
fact_scrape_run:finished_date_key:e -> dim_date:date_key:w [label="N:1 finish"];
fact_scrape_run:finished_time_key:e -> dim_time:time_key:w [label="N:1 finish"];
etl_note [shape=note, label="etl_batch adalah audit table\ntanpa foreign key ke fact", style=filled, fillcolor="#FFFBEA"];
etl_batch -> etl_note [style=dashed, arrowhead=none];
label="Relational Schema ndbc_dw (sesuai DDL)\nAK* pada fact_observation = pasangan (station_key, observed_at_utc)"; labelloc=t; fontsize=16;
}